DEBUG=True
DJANGO_SECRET_KEY=replace-with-a-secure-secret
ALLOWED_HOSTS=localhost,127.0.0.1,testserver,.ondigitalocean.app,spotter-ai-vob9r.ondigitalocean.app,spotter-ai.dev
CSRF_TRUSTED_ORIGINS=https://spotter-ai-vob9r.ondigitalocean.app,https://spotter-ai.dev,http://localhost:3000
SITE_DOMAIN=spotter-ai.dev

# Optional: use managed Postgres in production
# DATABASE_URL=postgresql://user:password@host:25060/defaultdb?sslmode=require

# Email provider settings
# Note for DigitalOcean Droplets:
# SMTP ports 25/465/587 can be blocked. Prefer an email provider with HTTPS API,
# or SMTP on an alternate port (for example 2525) if your provider supports it.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=spotter.ai2026@gmail.com
DEFAULT_FROM_EMAIL="Spotter.ai <noreply@spotter-ai.dev>"
EMAIL_HOST_PASSWORD=replace-with-gmail-app-password
EMAIL_TIMEOUT=10

# Optional social auth provider secrets
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_KEY_ID=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# Email verification setting
EMAIL_VERIFICATION_ENABLED=True

# API for the AI
OPENAI_API_KEY=
